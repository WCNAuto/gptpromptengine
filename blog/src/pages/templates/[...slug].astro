---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('templates');
  return posts.map(post => ({ params: { slug: post.id }, props: post }));
}

const post = Astro.props;
const { Content } = await render(post);
---
<!DOCTYPE html>
<html lang='en'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>{post.data.title}</title>
  <meta name='description' content={post.data.description} />
  <style>
    body { font-family:-apple-system,system-ui,sans-serif; color:#1a1a2e; background:#f8fafc; }
    .page { max-width:780px; margin:0 auto; padding:3rem 1.5rem; }
    .badge { display:inline-block; background:#f0f7ff; color:#2563eb; padding:3px 10px;
      border-radius:4px; font-size:0.75rem; font-weight:600; margin-right:6px; }
    h1 { font-size:2rem; line-height:1.2; margin:0.5rem 0; }
    .subtitle { font-size:1.1rem; color:#4b5563; margin:0.75rem 0; }
    .affiliate-bar { background:#fffbeb; border:1px solid #fde68a; border-radius:8px;
      padding:0.75rem 1rem; margin:1.5rem 0; font-size:0.9rem; }
    .affiliate-bar a { color:#d97706; font-weight:600; }
    .content { line-height:1.7; }
    .content h2 { font-size:1.3rem; margin:2rem 0 1rem; border-bottom:1px solid #f3f4f6; padding-bottom:0.5rem; }
    .content blockquote { background:#f8fafc; border-left:4px solid #2563eb;
      padding:1rem 1.25rem; margin:0.75rem 0; border-radius:0 6px 6px 0; }
    .pack-cta { background:#1e293b; color:white; border-radius:12px; padding:2rem;
      text-align:center; margin-top:3rem; }
    .btn { display:inline-block; background:#f59e0b; color:#1e293b; padding:12px 28px;
      border-radius:8px; font-weight:700; text-decoration:none; margin-top:1rem; }
  </style>
</head>
<body>
  <article class='page'>
    <span class='badge'>{post.data.profession}</span>
    <span class='badge'>{post.data.contentType}</span>
    <h1>{post.data.title}</h1>
    <p class='subtitle'>{post.data.description}</p>
    <div class='affiliate-bar'>
      These prompts work best with <a href='JASPER_AFFILIATE_LINK'>Jasper AI</a>
      or <a href='COPYAI_AFFILIATE_LINK'>Copy.ai</a>
    </div>
    <div class='content'><Content /></div>
    <div class='pack-cta'>
      <h3 style='color:white'>Want the complete prompt pack?</h3>
      <p style='color:#94a3b8;margin:0.5rem 0'>500+ prompts, organised and ready to use.</p>
      <a href='GUMROAD_LINK' class='btn'>Download the Full Pack — $19</a>
    </div>
  </article>
</body>
</html>
