---
import { getCollection } from 'astro:content';
const allWorkflows = await getCollection('workflows');
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Automation Workflows — GPT Prompt Engine</title>
<meta name="description" content="Free n8n automation workflow guides organised by profession. Node-by-node breakdowns with downloadable JSON." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,700&family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="sitemap" href="/sitemap-index.xml" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:root {
  --bg: #FFFFFF; --bg-soft: #F2F2F2; --bg-dark: #0C1D5B; --bg-deeper: #0A1645;
  --text: #0C1D5B; --text-soft: #6B7699; --text-muted: #8B93AB;
  --rule: #E5E8F0; --rule-strong: #C8CEDD;
  --blue: #0C1D5B; --blue-tint: #EAEDF5;
  --green: #CDE954; --green-deep: #B5D344;
  --display: 'Fraunces', Georgia, serif;
  --body: 'Instrument Sans', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
body { font-family:var(--body); background:var(--bg); color:var(--text); -webkit-font-smoothing:antialiased; line-height:1.6; }
a { color:inherit; text-decoration:none; }
.nav { position:sticky; top:0; z-index:100; background:var(--bg); border-bottom:1px solid var(--rule); padding:0 48px; display:flex; align-items:center; justify-content:space-between; height:64px; }
.nav-logo { font-family:var(--display); font-size:21px; font-weight:500; font-variation-settings:"opsz" 144; letter-spacing:-0.02em; color:var(--blue); display:flex; align-items:center; gap:7px; }
.nav-dot { width:8px; height:8px; border-radius:50%; background:var(--green); display:inline-block; animation:blink 2.5s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.35} }
.nav-center { display:flex; gap:4px; background:var(--bg-soft); padding:4px; border-radius:8px; }
.nav-link { padding:8px 16px; font-size:13px; font-weight:500; color:var(--text-soft); border-radius:5px; transition:all 0.15s; }
.nav-link:hover { color:var(--blue); background:rgba(12,29,91,0.04); }
.nav-link.active { background:var(--bg); color:var(--blue); font-weight:700; box-shadow:0 1px 3px rgba(12,29,91,0.08); }
.nav-cta { background:var(--green); color:var(--blue); padding:9px 20px; font-size:13px; font-weight:700; border-radius:6px; letter-spacing:0.01em; transition:all 0.15s; }
.nav-cta:hover { background:var(--green-deep); transform:translateY(-1px); }
.page-header { background:var(--bg-dark); padding:56px 48px 48px; border-bottom:3px solid var(--green); }
.page-header-inner { max-width:1100px; margin:0 auto; }
.page-header-crumb { font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:20px; display:flex; align-items:center; gap:8px; }
.page-header-crumb a { color:rgba(255,255,255,0.4); transition:color 0.15s; }
.page-header-crumb a:hover { color:var(--green); }
.page-header-crumb span { color:rgba(255,255,255,0.2); }
.page-header h1 { font-family:var(--display); font-weight:500; font-variation-settings:"opsz" 144; font-size:clamp(32px, 4vw, 48px); line-height:1.08; letter-spacing:-0.025em; color:white; margin-bottom:14px; }
.page-header h1 em { font-style:italic; color:var(--green); }
.page-header .lede { font-size:15px; color:rgba(255,255,255,0.55); line-height:1.65; max-width:560px; font-weight:400; }
.page-header-meta { display:flex; align-items:center; gap:24px; margin-top:28px; padding-top:24px; border-top:1px solid rgba(255,255,255,0.1); }
.meta-stat-num { font-family:var(--mono); font-size:20px; font-weight:600; color:white; line-height:1; margin-bottom:3px; }
.meta-stat-label { font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.35); }
.meta-divider { width:1px; height:32px; background:rgba(255,255,255,0.1); }
.n8n-strip { background:var(--blue-tint); border-bottom:1px solid var(--rule); padding:0 48px; }
.n8n-inner { max-width:1100px; margin:0 auto; height:48px; display:flex; align-items:center; gap:14px; }
.n8n-icon { width:26px; height:26px; background:var(--bg-dark); border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:12px; flex-shrink:0; }
.n8n-text { font-size:13px; color:var(--blue); font-weight:400; }
.n8n-text strong { font-weight:700; }
.n8n-text a { font-weight:700; color:var(--blue); border-bottom:1px dotted var(--blue); }
.main { max-width:1100px; margin:0 auto; padding:40px 48px 80px; }
.profession-group { margin-bottom:56px; }
.group-header { display:flex; align-items:center; gap:14px; margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid var(--rule); }
.group-icon { width:36px; height:36px; background:var(--bg-dark); color:var(--green); border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:16px; }
.group-title { font-size:18px; font-weight:700; color:var(--blue); }
.group-count { margin-left:auto; font-family:var(--mono); font-size:11px; font-weight:600; color:var(--blue); background:var(--blue-tint); padding:4px 12px; border-radius:999px; }
.group-link { font-size:12px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:var(--text-muted); transition:color 0.15s; display:flex; align-items:center; gap:5px; }
.group-link:hover { color:var(--blue); }
.cards-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:14px; }
.card { background:var(--bg); border:1px solid var(--rule); border-radius:10px; overflow:hidden; display:block; transition:all 0.2s; }
.card:hover { border-color:var(--rule-strong); box-shadow:0 6px 20px rgba(12,29,91,0.07); transform:translateY(-1px); }
.card-head { display:flex; align-items:center; gap:10px; padding:12px 16px; background:var(--bg-soft); border-bottom:1px solid var(--rule); }
.chip { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:999px; background:var(--blue-tint); color:var(--blue); }
.chip.orange { background:#FFF3EB; color:#B84A00; }
.chip-dot { width:5px; height:5px; border-radius:50%; background:currentColor; flex-shrink:0; }
.card-meta { margin-left:auto; font-family:var(--mono); font-size:10px; color:var(--text-muted); }
.card-nodes { display:flex; align-items:center; gap:6px; padding:12px 16px; border-bottom:1px solid var(--rule); overflow:hidden; }
.node-pill { display:inline-flex; align-items:center; gap:4px; font-family:var(--mono); font-size:10px; font-weight:600; background:var(--bg-dark); color:var(--green); padding:3px 8px; border-radius:4px; white-space:nowrap; flex-shrink:0; }
.node-arrow { font-size:10px; color:var(--rule-strong); flex-shrink:0; }
.node-more { font-family:var(--mono); font-size:10px; color:var(--text-muted); flex-shrink:0; }
.card-body { padding:14px 16px; }
.card-title { font-size:14px; font-weight:700; color:var(--blue); line-height:1.35; margin-bottom:6px; }
.card-desc { font-size:12px; color:var(--text-soft); line-height:1.6; }
.card-footer { display:flex; align-items:center; justify-content:space-between; padding:10px 16px; border-top:1px solid var(--rule); background:var(--bg-soft); }
.card-tags { display:flex; gap:6px; flex-wrap:wrap; }
.card-tag { font-size:10px; font-weight:600; color:var(--text-muted); background:var(--bg); border:1px solid var(--rule); padding:2px 8px; border-radius:4px; }
.card-download { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; color:var(--blue); transition:color 0.15s; }
.card-download:hover { color:var(--green-deep); }
.card-download-icon { width:22px; height:22px; background:var(--green); color:var(--blue); border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:10px; }
.empty-group { background:var(--bg-soft); border:1px dashed var(--rule-strong); border-radius:10px; padding:28px 24px; display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
.empty-card { background:var(--bg); border:1px solid var(--rule); border-radius:8px; padding:14px; opacity:0.5; }
.empty-card-line { height:10px; background:var(--rule); border-radius:4px; margin-bottom:8px; }
.empty-card-line.short { width:60%; }
.empty-card-line.shorter { width:40%; }
.empty-badge { height:18px; width:60px; background:var(--rule); border-radius:999px; margin-bottom:10px; }
.coming-label { grid-column:1/-1; text-align:center; padding:8px 0 0; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted); }
footer { background:var(--bg-deeper); border-top:1px solid rgba(255,255,255,0.06); padding:28px 48px; }
.footer-inner { max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
.footer-logo { font-family:var(--display); font-size:16px; font-weight:500; font-variation-settings:"opsz" 144; color:rgba(255,255,255,0.45); display:flex; align-items:center; gap:6px; }
.footer-logo-dot { width:6px; height:6px; border-radius:50%; background:var(--green); }
.footer-links { display:flex; gap:24px; list-style:none; }
.footer-links a { font-size:12px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.25); transition:color 0.15s; }
.footer-links a:hover { color:rgba(255,255,255,0.7); }
.footer-copy { font-family:var(--mono); font-size:11px; color:rgba(255,255,255,0.2); }
@media (max-width:960px) {
  nav,.page-header,.n8n-strip,.main,footer { padding-left:20px; padding-right:20px; }
  .cards-grid { grid-template-columns:1fr; }
}
</style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo"><span class="nav-dot"></span>GPT Prompt Engine</a>
  <div class="nav-center">
    <a href="/prompts" class="nav-link">Prompts</a>
    <a href="/workflows" class="nav-link active">Workflows</a>
    <a href="/templates" class="nav-link">Templates</a>
  </div>
  <a href="/hr-managers" class="nav-cta">Browse Free</a>
</nav>

<div class="page-header">
  <div class="page-header-inner">
    <div class="page-header-crumb"><a href="/">Home</a><span>/</span>Workflows</div>
    <h1>Automation workflows for<br/><em>every repetitive task.</em></h1>
    <p class="lede">Node-by-node n8n workflow guides with downloadable JSON. Import directly into your n8n instance — no coding, no terminal required.</p>
    <div class="page-header-meta">
      <div class="meta-stat">
        <div class="meta-stat-num">1</div>
        <div class="meta-stat-label">Workflow live</div>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-stat">
        <div class="meta-stat-num">JSON</div>
        <div class="meta-stat-label">Downloadable</div>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-stat">
        <div class="meta-stat-num">100%</div>
        <div class="meta-stat-label">Free to use</div>
      </div>
    </div>
  </div>
</div>

<div class="n8n-strip">
  <div class="n8n-inner">
    <div class="n8n-icon">⚡</div>
    <p class="n8n-text"><strong>These workflows run on n8n.</strong> Free to self-host or use <a href="https://n8n.io" target="_blank">n8n Cloud</a> — no coding required. Each page includes a downloadable JSON file you import in one click.</p>
  </div>
</div>

<main class="main">
  <div class="profession-group">
    <div class="group-header">
      <div class="group-icon">👥</div>
      <div class="group-title">HR Managers</div>
      <span class="group-count">1 workflow</span>
      <a href="/hr-managers" class="group-link">View hub →</a>
    </div>
    <div class="cards-grid">
      <a href="/workflows/hr-job-posting-linkedin" class="card">
        <div class="card-head">
          <span class="chip orange"><span class="chip-dot"></span>Workflow</span>
          <span class="card-meta">7 nodes</span>
        </div>
        <div class="card-nodes">
          <span class="node-pill">📋 Form trigger</span>
          <span class="node-arrow">→</span>
          <span class="node-pill">🤖 Claude API</span>
          <span class="node-arrow">→</span>
          <span class="node-pill">💼 LinkedIn</span>
          <span class="node-more">+4 more</span>
        </div>
        <div class="card-body">
          <div class="card-title">n8n Workflow for Automating Job Posting to LinkedIn</div>
          <div class="card-desc">Fill in a form, Claude writes the post, it goes live on LinkedIn and updates your Notion tracker — automatically.</div>
        </div>
        <div class="card-footer">
          <div class="card-tags">
            <span class="card-tag">Recruitment</span>
            <span class="card-tag">LinkedIn</span>
            <span class="card-tag">HR Managers</span>
          </div>
          <span class="card-download"><span class="card-download-icon">↓</span> JSON</span>
        </div>
      </a>
    </div>
  </div>

  <div class="profession-group">
    <div class="group-header">
      <div class="group-icon">📣</div>
      <div class="group-title">Marketing Managers</div>
      <span class="group-count" style="background:var(--bg-soft);color:var(--text-muted);">Coming soon</span>
      <a href="/marketing-managers" class="group-link">View hub →</a>
    </div>
    <div class="empty-group">
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="coming-label">Lead nurturing · Social scheduling · Report generation — publishing soon</div>
    </div>
  </div>

  <div class="profession-group">
    <div class="group-header">
      <div class="group-icon">⚙️</div>
      <div class="group-title">Operations Managers</div>
      <span class="group-count" style="background:var(--bg-soft);color:var(--text-muted);">Coming soon</span>
      <a href="/operations-managers" class="group-link">View hub →</a>
    </div>
    <div class="empty-group">
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="empty-card"><div class="empty-badge"></div><div class="empty-card-line"></div><div class="empty-card-line short"></div><div class="empty-card-line shorter"></div></div>
      <div class="coming-label">Invoice processing · Weekly reports · SOP automation — publishing soon</div>
    </div>
  </div>
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-logo"><span class="footer-logo-dot"></span>GPT Prompt Engine</div>
    <ul class="footer-links">
      <li><a href="/prompts">Prompts</a></li>
      <li><a href="/workflows">Workflows</a></li>
      <li><a href="/templates">Templates</a></li>
    </ul>
    <div class="footer-copy">gptpromptengine.com &middot; A WDC property &middot; 2026</div>
  </div>
</footer>

</body>
</html>
