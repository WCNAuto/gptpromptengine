---
import { getCollection, render } from 'astro:content';
import GlobalFooter from '../../components/GlobalFooter.astro'; 

export async function getStaticPaths() {
  const posts = await getCollection('workflows');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings } = await render(post);
const professionSlug = post.data.profession.toLowerCase().replace(/\s+/g, '-');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{post.data.title}</title>
<meta name="description" content={post.data.description} />
<link rel="canonical" href={canonicalUrl} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="sitemap" href="/sitemap-index.xml" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:root {
  --bg: #FFFFFF; --bg-soft: #F2F2F2; --bg-dark: #0C1D5B; --bg-deeper: #0A1645;
  --text: #0C1D5B; --text-soft: #6B7699; --text-muted: #8B93AB;
  --rule: #E5E8F0; --rule-strong: #C8CEDD;
  --blue: #0C1D5B; --blue-tint: #EAEDF5;
  --green: #CDE954; --green-deep: #B5D344;
  --body: 'Carlito', 'Calibri', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
body { font-family:var(--body); background:var(--bg); color:var(--text); -webkit-font-smoothing:antialiased; line-height:1.6; }
a { color:inherit; text-decoration:none; }
.nav { position:sticky; top:0; z-index:100; background:var(--bg); border-bottom:1px solid var(--rule); padding:0 48px; display:flex; align-items:center; justify-content:space-between; height:64px; }
.nav-logo { font-size:18px; font-weight:700; color:var(--blue); display:flex; align-items:center; gap:7px; }
.nav-dot { width:8px; height:8px; border-radius:50%; background:var(--green); display:inline-block; }
.nav-center { display:flex; gap:4px; background:var(--bg-soft); padding:4px; border-radius:8px; }
.nav-link { padding:8px 16px; font-size:13px; font-weight:500; color:var(--text-soft); border-radius:5px; transition:all 0.15s; }
.nav-link:hover { color:var(--blue); }
.nav-link.active { background:var(--bg); color:var(--blue); font-weight:700; box-shadow:0 1px 3px rgba(12,29,91,0.08); }
.nav-cta { background:var(--green); color:var(--blue); padding:9px 20px; font-size:13px; font-weight:700; border-radius:6px; transition:all 0.15s; }
.nav-cta:hover { background:var(--green-deep); }
.hero { background:var(--bg); border-bottom:1px solid var(--rule); padding:40px 48px 32px; }
.hero-inner { max-width:900px; margin:0 auto; }
.crumbs { font-size:13px; color:var(--text-muted); margin-bottom:16px; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.crumbs a { color:var(--text-muted); transition:color 0.15s; }
.crumbs a:hover { color:var(--blue); }
.crumbs span { color:var(--rule-strong); }
.chip { display:inline-flex; align-items:center; gap:5px; font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:999px; background:#FFF3EB; color:#B84A00; margin-bottom:14px; }
.chip-dot { width:5px; height:5px; border-radius:50%; background:currentColor; }
.hero h1 { font-size:clamp(24px,3vw,36px); font-weight:700; line-height:1.2; letter-spacing:-0.02em; color:var(--blue); margin-bottom:12px; }
.hero .lede { font-size:15px; color:var(--text-soft); line-height:1.65; max-width:680px; }
.content { max-width:900px; margin:0 auto; padding:40px 48px 80px; }
.content h2 { font-size:22px; font-weight:700; color:var(--blue); margin:40px 0 16px; padding-top:16px; border-top:1px solid var(--rule); }
.content h2:first-child { margin-top:0; border-top:none; padding-top:0; }
.content h3 { font-size:17px; font-weight:700; color:var(--blue); margin:24px 0 10px; }
.content p { font-size:15px; line-height:1.7; color:var(--text-soft); margin-bottom:14px; }
.content ul, .content ol { padding-left:20px; margin-bottom:14px; }
.content li { font-size:15px; line-height:1.7; color:var(--text-soft); margin-bottom:6px; }
.content blockquote { background:var(--bg-dark); color:rgba(255,255,255,0.88); padding:20px 24px; border-radius:8px; margin:20px 0; }
.content blockquote p { font-family:var(--mono); font-size:13px; line-height:1.7; color:inherit; margin:0; }
.content hr { border:none; border-top:1px solid var(--rule); margin:32px 0; }
.content strong { color:var(--blue); font-weight:700; }
.content a { color:var(--blue); font-weight:600; border-bottom:1px dotted var(--blue); }
footer { background:var(--bg-deeper); border-top:1px solid rgba(255,255,255,0.06); padding:28px 48px; }
.footer-inner { max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
.footer-logo { font-size:15px; font-weight:600; color:rgba(255,255,255,0.45); display:flex; align-items:center; gap:6px; }
.footer-dot { width:6px; height:6px; border-radius:50%; background:var(--green); }
.footer-links { display:flex; gap:24px; list-style:none; }
.footer-links a { font-size:12px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.25); }
.footer-links a:hover { color:rgba(255,255,255,0.7); }
.footer-copy { font-family:var(--mono); font-size:11px; color:rgba(255,255,255,0.2); }
@media (max-width:768px) {
  .nav { padding:12px 20px; flex-wrap:wrap; gap:10px; }
  .nav-center { order:3; width:100%; justify-content:center; }
  .hero, .content, footer { padding-left:20px; padding-right:20px; }
}
/* MOBILE NAV */
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
  background: none;
  border: none;
}
.nav-hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--blue);
  border-radius: 2px;
  transition: all 0.25s;
}
.nav-mobile-menu {
  display: none;
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  background: white;
  border-bottom: 1px solid var(--rule);
  padding: 16px 20px;
  z-index: 99;
  flex-direction: column;
  gap: 4px;
}
.nav-mobile-menu.open { display: flex; }
.nav-mobile-menu a {
  padding: 12px 16px;
  font-size: 15px;
  font-weight: 500;
  color: var(--blue);
  border-radius: 8px;
}
.nav-mobile-menu a:hover { background: var(--bg-soft); }
.nav-mobile-menu .mob-cta {
  margin-top: 8px;
  background: var(--green);
  color: var(--blue);
  font-weight: 700;
  text-align: center;
}

@media (max-width: 768px) {
  .nav-center { display: none; }
  .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
}
</style>
</head>
<body>

<nav class="nav">
<div class="nav-mobile-menu" id="mobileMenu">
  <a href="/prompts">Prompts</a>
  <a href="/workflows">Workflows</a>
  <a href="/templates">Templates</a>
  <a href="/hr-managers" class="mob-cta">Browse Free</a>
</div>
  <a href="/" class="nav-logo"><span class="nav-dot"></span>GPT Prompt Engine</a>
  <div class="nav-center">
    <a href="/prompts" class="nav-link">Prompts</a>
    <a href="/workflows" class="nav-link active">Workflows</a>
    <a href="/templates" class="nav-link">Templates</a>
  </div>
  <a href={`/${professionSlug}`} class="nav-cta">Browse {post.data.profession}</a>
  <button class="nav-hamburger" id="hamburger" aria-label="Menu">
  <span></span><span></span><span></span>
</button>
</nav>

<header class="hero">
  <div class="hero-inner">
    <div class="crumbs">
      <a href="/">Home</a><span>/</span>
      <a href="/workflows">Workflows</a><span>/</span>
      <a href={`/${professionSlug}`}>{post.data.profession}</a><span>/</span>
      <strong>{post.data.category}</strong>
    </div>
    <div class="chip"><span class="chip-dot"></span>Workflow · {post.data.profession}</div>
    <h1>{post.data.title}</h1>
    <p class="lede">{post.data.description}</p>
  </div>
</header>

<main class="content">
  <Content />
</main>
<script is:inline>
  document.getElementById('hamburger').addEventListener('click', () => {
    document.getElementById('mobileMenu').classList.toggle('open');
  });
</script>
<GlobalFooter />

</body>
</html>
