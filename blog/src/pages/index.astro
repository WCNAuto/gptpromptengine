---
import { getCollection } from 'astro:content';
const prompts = await getCollection('prompts');
const workflows = await getCollection('workflows');
const templates = await getCollection('templates');
const allContent = [...prompts, ...workflows, ...templates]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const professions = [...new Set(allContent.map(p => p.data.profession))];
---
<!DOCTYPE html>
<html lang='en'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Free AI Prompts, Workflows and Templates by Profession</title>
  <meta name='description' content='The most comprehensive free AI resource library
    organised by job role. Prompts, n8n workflows and Notion templates.' />
  <link rel='sitemap' href='/sitemap-index.xml' />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: -apple-system, system-ui, sans-serif; color:#1a1a2e; background:#f8fafc; }
    header { background:white; border-bottom:1px solid #e5e7eb; padding:1rem 2rem; }
    nav { max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; }
    .logo { font-weight:800; font-size:1.3rem; text-decoration:none; color:#1a1a2e; }
    .nav-links a { margin-left:1.5rem; text-decoration:none; color:#6b7280; font-size:0.9rem; }
    .hero { max-width:1100px; margin:0 auto; padding:4rem 2rem 3rem; text-align:center; }
    .hero h1 { font-size:2.5rem; font-weight:800; line-height:1.2; }
    .hero p { margin-top:1rem; font-size:1.1rem; color:#6b7280; }
    section { max-width:1100px; margin:0 auto; padding:2rem; }
    h2 { font-size:1.4rem; font-weight:700; margin-bottom:1rem; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; }
    .card, .profession-card { display:block; background:white; border:1px solid #e5e7eb;
      border-radius:8px; padding:1rem; text-decoration:none; color:inherit; }
    .card:hover, .profession-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.08); }
    .profession-card { display:flex; flex-direction:column; gap:0.3rem; }
    .profession-card strong { font-size:1rem; }
    .profession-card span { font-size:0.8rem; color:#9ca3af; }
    .card h3 { font-size:0.95rem; margin:0.5rem 0; line-height:1.4; }
    .card .meta { font-size:0.8rem; color:#9ca3af; }
    .type-badge { font-size:0.7rem; font-weight:600; text-transform:uppercase;
      letter-spacing:0.05em; background:#f0f7ff; color:#2563eb; padding:2px 8px;
      border-radius:4px; }
  </style>
<!-- Google tag (gtag.js) --> 
<script async src="https://www.googletagmanager.com/gtag/js?id=G-30G6MSESFG">
</script>
<script>   window.dataLayer = window.dataLayer || [];   function gtag(){dataLayer.push(arguments);}   gtag('js', new Date());   gtag('config', 'G-30G6MSESFG');> </script>
</head>
<body>
  <header>
    <nav>
      <a href='/' class='logo'>GPT Prompt Engine</a>
      <div class='nav-links'>
        <a href='/prompts'>Prompts</a>
        <a href='/workflows'>Workflows</a>
        <a href='/templates'>Templates</a>
      </div>
    </nav>
  </header>
  <main>
    <section class='hero'>
      <h1>AI Resources Built for Your Profession</h1>
      <p>Prompt libraries, automation workflows, and templates — organised by job role.</p>
    </section>
    <section class='professions'>
      <h2>Browse by Profession</h2>
      <div class='grid'>
        {professions.map(p => (
          <a href={`/${p.toLowerCase().replace(/\s+/g, '-')}`} class='profession-card'>
            <strong>{p}</strong>
            <span>{allContent.filter(c => c.data.profession === p).length} resources</span>
          </a>
        ))}
      </div>
    </section>
    <section class='latest'>
      <h2>Latest Resources</h2>
      <div class='grid'>
        {allContent.slice(0, 12).map(post => (
          <a href={`/${post.collection}/${post.id}`} class='card'>
            <span class='type-badge'>{post.data.contentType}</span>
            <h3>{post.data.title}</h3>
            <p class='meta'>{post.data.profession}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</body>
</html>
