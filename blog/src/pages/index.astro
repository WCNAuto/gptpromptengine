<link rel="sitemap" href="/sitemap-index.xml" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:root {
  --bg: #FFFFFF; --bg-soft: #F2F2F2; --bg-dark: #0C1D5B; --bg-deeper: #0A1645;
  --text: #0C1D5B; --text-soft: #6B7699; --text-muted: #8B93AB;
  --rule: #E5E8F0; --rule-strong: #C8CEDD;
  --blue: #0C1D5B; --blue-tint: #EAEDF5;
  --green: #CDE954; --green-deep: #B5D344;
  --display: 'Carlito', 'Calibri', sans-serif;  --body: 'Carlito', 'Calibri', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
body { font-family: var(--body); background: var(--bg); color: var(--text); -webkit-font-smoothing: antialiased; overflow-x: hidden; line-height: 1.6; }
a { color: inherit; text-decoration: none; }
.nav { position: sticky; top: 0; z-index: 100; background: var(--bg); border-bottom: 1px solid var(--rule); padding: 0 48px; display: flex; align-items: center; justify-content: space-between; height: 64px; }
.nav-logo { font-family: var(--display); font-size: 21px; font-weight: 500; font-variation-settings: "opsz" 144; letter-spacing: -0.02em; color: var(--blue); display: flex; align-items: center; gap: 7px; }
.nav-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); display: inline-block; animation: blink 2.5s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.35} }
.nav-center { display: flex; gap: 4px; background: var(--bg-soft); padding: 4px; border-radius: 8px; }
.nav-link { padding: 8px 16px; font-size: 13px; font-weight: 500; color: var(--text-soft); border-radius: 5px; transition: all 0.15s; }
.nav-link:hover { color: var(--blue); background: rgba(12,29,91,0.04); }
.nav-cta { background: var(--green); color: var(--blue); padding: 9px 20px; font-size: 13px; font-weight: 700; border-radius: 6px; letter-spacing: 0.01em; transition: all 0.15s; }
.nav-cta:hover { background: var(--green-deep); transform: translateY(-1px); }
.hero { border-bottom: 1px solid var(--rule); padding: 80px 48px 72px; }
.hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 400px; gap: 64px; align-items: center; }
.hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
.hero-eyebrow::before { content:''; display:block; width:18px; height:2px; background:var(--green); }
.hero h1 { font-family: var(--display); font-weight: 500; font-variation-settings: "opsz" 144; font-size: clamp(40px, 5vw, 60px); line-height: 1.05; letter-spacing: -0.025em; color: var(--text); margin-bottom: 20px; }
.hero h1 em { font-style: italic; }
.hero .lede { font-family: var(--display); font-weight: 300; font-variation-settings: "opsz" 90; font-style: italic; font-size: 19px; line-height: 1.55; color: var(--text-soft); max-width: 520px; margin-bottom: 36px; }
.hero-actions { display: flex; gap: 12px; align-items: center; }
.btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--blue); color: white; padding: 14px 28px; font-family: var(--body); font-size: 14px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; border-radius: 4px; transition: all 0.2s; }
.btn-primary:hover { background: var(--bg-deeper); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(12,29,91,0.2); }
.btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--blue); padding: 14px 24px; font-family: var(--body); font-size: 14px; font-weight: 600; border: 1.5px solid var(--rule-strong); border-radius: 4px; transition: all 0.15s; }
.btn-secondary:hover { border-color: var(--blue); }
.hero-right { display: flex; flex-direction: column; gap: 12px; }
.preview-card { background: var(--bg); border: 1px solid var(--rule); border-radius: 10px; overflow: hidden; transition: box-shadow 0.2s; }
.preview-card:hover { box-shadow: 0 6px 20px rgba(12,29,91,0.08); }
.preview-head { display: flex; align-items: center; gap: 10px; padding: 11px 16px; background: var(--bg-soft); border-bottom: 1px solid var(--rule); }
.chip { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 10px; border-radius: 999px; background: var(--blue-tint); color: var(--blue); }
.chip.green { background: var(--green); color: var(--blue); }
.chip-dot { width:5px; height:5px; border-radius:50%; background:currentColor; flex-shrink:0; }
.preview-prof { margin-left:auto; font-size:11px; font-weight:600; color:var(--text-muted); }
.preview-body { padding: 14px 16px; }
.preview-title { font-size:14px; font-weight:600; color:var(--blue); margin-bottom:8px; line-height:1.35; }
.preview-prompt { background: var(--bg-dark); border-radius:6px; padding:10px 14px; font-family: var(--mono); font-size:11px; line-height:1.65; color: rgba(255,255,255,0.85); }
.preview-prompt .var { color: var(--green); font-weight:600; }
.mini-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.mini-card { background: var(--bg); border: 1px solid var(--rule); border-radius: 10px; padding: 14px; transition: box-shadow 0.2s; }
.mini-card:hover { box-shadow: 0 4px 12px rgba(12,29,91,0.06); }
.mini-title { font-size:12px; font-weight:600; color:var(--blue); margin:8px 0 4px; line-height:1.3; }
.mini-sub { font-size:11px; color:var(--text-muted); line-height:1.5; }
.ticker-wrap { background: var(--bg-dark); overflow:hidden; padding:11px 0; border-bottom:3px solid var(--green); }
.ticker-track { display:flex; width:max-content; animation: slide 30s linear infinite; }
@keyframes slide { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.ticker-item { display:flex; align-items:center; gap:10px; padding:0 28px; font-size:12px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.4); white-space:nowrap; }
.ticker-item strong { color:rgba(255,255,255,0.85); }
.ticker-pip { width:5px; height:5px; border-radius:50%; background:var(--green); flex-shrink:0; }
.types { background: var(--bg-soft); border-bottom: 1px solid var(--rule); }
.types-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); }
.type-block { padding: 40px 36px; border-right: 1px solid var(--rule); position: relative; background: var(--bg-soft); transition: background 0.2s; }
.type-block:last-child { border-right: none; }
.type-block:hover { background: var(--bg); }
.type-block::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background: transparent; transition: background 0.2s; }
.type-block:hover::before { background: var(--green); }
.type-icon { width:40px; height:40px; background:var(--bg-dark); color:var(--green); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:16px; }
.type-block h3 { font-size:16px; font-weight:700; color:var(--blue); margin-bottom:8px; }
.type-block p { font-size:13px; color:var(--text-soft); line-height:1.65; margin-bottom:12px; }
.type-url { font-family:var(--mono); font-size:11px; color:var(--text-muted); }
.type-num { position:absolute; bottom:18px; right:22px; font-family:var(--display); font-style:italic; font-variation-settings:"opsz" 144; font-size:52px; font-weight:300; color:var(--rule); line-height:1; pointer-events:none; }
.professions { background: var(--bg-dark); padding: 80px 48px; }
.prof-inner { max-width: 1100px; margin: 0 auto; }
.section-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--green); margin-bottom:16px; display:flex; align-items:center; gap:10px; }
.section-eyebrow::before { content:''; display:block; width:18px; height:2px; background:var(--green); }
.section-heading { font-family:var(--display); font-weight:500; font-variation-settings:"opsz" 144; font-size:clamp(28px, 3.5vw, 42px); line-height:1.1; letter-spacing:-0.02em; margin-bottom:12px; }
.section-heading em { font-style:italic; }
.section-sub { font-size:15px; line-height:1.65; max-width:500px; font-weight:400; margin-bottom:40px; }
.professions .section-heading { color:white; }
.professions .section-sub { color:rgba(255,255,255,0.5); }
.prof-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 12px; }
.prof-card { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:10px; padding:20px; display:block; transition:all 0.2s; }
.prof-card:hover { background:rgba(255,255,255,0.09); border-color:rgba(205,233,84,0.4); transform:translateY(-2px); }
.prof-wave { display:inline-block; font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:3px 8px; border-radius:999px; margin-bottom:10px; background:rgba(205,233,84,0.15); color:var(--green); }
.prof-wave.soon { background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.3); }
.prof-name { font-size:14px; font-weight:700; color:white; margin-bottom:4px; }
.prof-sub { font-size:12px; font-family:var(--mono); color:rgba(255,255,255,0.3); line-height:1.5; }
.prof-arrow { margin-top:14px; font-size:14px; color:rgba(255,255,255,0.15); transition:color 0.2s; }
.prof-card:hover .prof-arrow { color:var(--green); }
.cta-section { background: var(--bg-dark); padding: 88px 48px; text-align: center; position: relative; overflow: hidden; }
.cta-section::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:var(--green); }
.cta-inner { max-width: 680px; margin: 0 auto; }
.cta-eyebrow { font-size:11px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--green); margin-bottom:20px; display:flex; align-items:center; justify-content:center; gap:10px; }
.cta-eyebrow::before,.cta-eyebrow::after { content:''; display:block; width:18px; height:2px; background:var(--green); }
.cta-heading { font-family:var(--display); font-weight:500; font-variation-settings:"opsz" 144; font-size:clamp(28px,3.5vw,42px); line-height:1.1; letter-spacing:-0.02em; color:white; margin-bottom:16px; }
.cta-heading em { font-style:italic; color:var(--green); }
.cta-sub { font-size:15px; color:rgba(255,255,255,0.5); line-height:1.65; margin-bottom:40px; }
.cta-buttons { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
.btn-green { display:inline-flex; align-items:center; gap:8px; background:var(--green); color:var(--blue); padding:16px 32px; font-family:var(--body); font-size:14px; font-weight:700; letter-spacing:0.03em; text-transform:uppercase; border-radius:4px; transition:all 0.2s; }
.btn-green:hover { background:var(--green-deep); transform:translateY(-2px); box-shadow:0 8px 24px rgba(205,233,84,0.3); }
.btn-ghost { display:inline-flex; align-items:center; gap:8px; background:transparent; color:rgba(255,255,255,0.55); padding:16px 28px; font-family:var(--body); font-size:14px; font-weight:600; border:1.5px solid rgba(255,255,255,0.2); border-radius:4px; transition:all 0.15s; }
.btn-ghost:hover { border-color:rgba(255,255,255,0.5); color:white; }
footer { background:var(--bg-deeper); border-top:1px solid rgba(255,255,255,0.06); padding:28px 48px; }
.footer-inner { max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
.footer-logo { font-family:var(--display); font-size:16px; font-weight:500; font-variation-settings:"opsz" 144; color:rgba(255,255,255,0.45); display:flex; align-items:center; gap:6px; }
.footer-logo-dot { width:6px; height:6px; border-radius:50%; background:var(--green); }
.footer-links { display:flex; gap:24px; list-style:none; }
.footer-links a { font-size:12px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.25); transition:color 0.15s; }
.footer-links a:hover { color:rgba(255,255,255,0.7); }
.footer-copy { font-family:var(--mono); font-size:11px; color:rgba(255,255,255,0.2); }
.reveal { opacity:0; transform:translateY(16px); transition:opacity 0.55s ease, transform 0.55s ease; }
.reveal.on { opacity:1; transform:translateY(0); }
@media (max-width: 960px) {
  .hero-inner { grid-template-columns:1fr; }
  .hero-right { display:none; }
  .types-grid { grid-template-columns:1fr; }
  .type-block { border-right:none; border-bottom:1px solid var(--rule); }
  nav,.hero,.professions,.cta-section,footer { padding-left:24px; padding-right:24px; }
}
</style>
